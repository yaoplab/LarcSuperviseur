-- Name: student_daily_summary; Type: VIEW; Schema: public; Owner: postgres
--

CREATE VIEW public.student_daily_summary AS
 SELECT se.student_id,
    ag.date_all AS day,
    ag.working_day,
    ag.day_notice,
        CASE
            WHEN (EXISTS ( SELECT 1
               FROM public.student_event e2
              WHERE ((e2.student_id = se.student_id) AND (e2.agenda_day_id = ag.id) AND (e2.event_type = 'absence'::text) AND (e2.validated_by IS NULL)))) THEN 'ABSENT'::text
            WHEN (EXISTS ( SELECT 1
               FROM public.student_event e3
              WHERE ((e3.student_id = se.student_id) AND (e3.agenda_day_id = ag.id) AND (e3.event_type <> 'absence'::text)))) THEN 'PRESENT'::text
            ELSE 'UNKNOWN'::text
        END AS presence,
    min(
        CASE
            WHEN (se.event_type = 'arrival'::text) THEN se.event_at
            ELSE NULL::timestamp without time zone
        END) AS first_arrival,
    max(
        CASE
            WHEN (se.event_type = 'departure'::text) THEN se.event_at
            ELSE NULL::timestamp without time zone
        END) AS last_departure,
    count(*) FILTER (WHERE (se.event_type = 'exit'::text)) AS exit_count,
    count(*) FILTER (WHERE (se.event_type = 'late'::text)) AS late_count,
    count(*) FILTER (WHERE ((se.event_type = 'absence'::text) AND (se.validated_by IS NULL))) AS absence_count,
    count(*) FILTER (WHERE (se.event_type = 'justified'::text)) AS justified_count,
    count(*) AS total_events
   FROM (public.student_event se
     JOIN public.larcauth_agenda ag ON ((ag.id = se.agenda_day_id)))
  GROUP BY se.student_id, ag.id, ag.date_all, ag.working_day, ag.day_notice;


