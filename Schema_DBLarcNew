-- TOC entry 274 (class 1259 OID 49200)
-- Name: student_alerts; Type: VIEW; Schema: public; Owner: postgres
--

CREATE VIEW public.student_alerts AS
 SELECT se.student_id,
    (((aec.last_name)::text || ' '::text) || (aec.first_name)::text) AS student_name,
    ag.date_all AS day,
    ag.working_day,
    ag.day_notice,
    count(*) FILTER (WHERE (se.event_type = 'exit'::text)) AS exit_count,
        CASE
            WHEN (count(*) FILTER (WHERE ((se.event_type = 'absence'::text) AND (se.validated_by IS NULL))) > 0) THEN true
            ELSE false
        END AS has_unjustified_absence,
    max(se.event_at) AS last_event
   FROM (((public.student_event se
     JOIN public.larcauth_agenda ag ON ((ag.id = se.agenda_day_id)))
     JOIN public.larcauth_student s ON ((s.aecuser_ptr_id = se.student_id)))
     JOIN public.larcauth_aecuser aec ON ((aec.id = s.aecuser_ptr_id)))
  WHERE (se.event_at >= (CURRENT_DATE - '7 days'::interval))
  GROUP BY se.student_id, aec.last_name, aec.first_name, ag.id, ag.date_all, ag.working_day, ag.day_notice
 HAVING ((count(*) FILTER (WHERE (se.event_type = 'exit'::text)) >= 3) OR (count(*) FILTER (WHERE ((se.event_type = 'absence'::text) AND (se.validated_by IS NULL))) > 0))
  ORDER BY
        CASE
            WHEN (count(*) FILTER (WHERE ((se.event_type = 'absence'::text) AND (se.validated_by IS NULL))) > 0) THEN true
            ELSE false
        END DESC, (count(*) FILTER (WHERE (se.event_type = 'exit'::text))) DESC;


